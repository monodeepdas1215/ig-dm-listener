# =============================================================================
# IG DM Listener — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#
#   cp .env.example .env
#
# IMPORTANT: Do NOT use 'export' prefix — Docker's env_file doesn't support it.
# =============================================================================

# --- Instagram Credentials (required) ---
IG_USERNAME="your_instagram_username"
IG_PASSWORD="your_instagram_password"
IG_DM_SENDER_USERNAME="sender_username_to_filter"
DM_FETCH_LIMIT=5

# --- Meta Webhook (optional — legacy) ---
META_VERIFY_TOKEN=your_meta_verify_token
META_PAGE_ACCESS_TOKEN="your_meta_page_access_token"

# --- Logging ---
LOG_LEVEL="DEBUG"
LOG_DEBUG="true"
LOG_DIR="logs"

# --- Resilience: Retry ---
RETRY_MAX_RETRIES=3
RETRY_BASE_DELAY=15.0
RETRY_MAX_DELAY=120.0

# --- Resilience: LLM Throttle ---
LLM_MAX_CONCURRENT=2
LLM_INTER_CALL_DELAY_MAX=90.0

# --- Resilience: Download Throttle ---
DOWNLOAD_MAX_CONCURRENT=3
DOWNLOAD_INTER_CALL_DELAY_MAX=30.0

# --- Backfill ---
BACKFILL_BATCH_SIZE=5
BACKFILL_STALE_THRESHOLD_MINUTES=15

# --- PostgreSQL ---
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://igapp:change_me@localhost:5432/ig_dm_listener
DB_POOL_MIN=2
DB_POOL_MAX=10
DROP_DB_ON_START=false

# --- LLM API Keys ---
ZAI_API_KEY="your-zai-api-key"
GOOGLE_API_KEY="your_google_api_key"

# --- Obsidian Knowledge Base ---
OBSIDIAN_API_KEY=your-obsidian-key
OBSIDIAN_VAULT_FOLDER="raw/instaKB"

