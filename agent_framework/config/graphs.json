      "checkpointer": "memory",
      "entry_point": "read_inbox",
      "finish_point": "report",
      "nodes": [
        {
          "name": "read_inbox",
          "type": "graph-node",
          "path": "agent_framework.graphs.insta_reel_downloader.nodes.read_inbox.ReadInboxNode"
        },
        {
          "name": "download_reels",
          "type": "graph-node",
          "path": "agent_framework.graphs.insta_reel_downloader.nodes.download_reels.DownloadReelsNode"
        },
        {
          "name": "report",
          "type": "graph-node",
          "path": "agent_framework.graphs.insta_reel_downloader.nodes.report.ReportNode"
        }
      ],
      "edges": [
        {
          "from": "read_inbox",
          "to": "download_reels",
          "condition": {
            "handler": "agent_framework.graphs.insta_reel_downloader.edges.conditions.has_new_reels"
          }
        },
        {
          "from": "read_inbox",
          "to": "report",
          "condition": {
            "handler": "agent_framework.graphs.insta_reel_downloader.edges.conditions.no_new_reels"
          }
